@{
    ViewData["Title"] = "Searching & Hashing - VisualizedAlgorithms";
}

<nav class="vs-nav" id="vs-nav">
    <div class="vs-nav-inner">
        <a asp-controller="Home" asp-action="Index" class="vs-nav-logo"><span class="logo-bracket">{</span>VisualizedAlgorithms<span class="logo-bracket">}</span></a>
        <div class="vs-nav-links">
            <a asp-controller="Home" asp-action="Sorting" class="vs-nav-link">Sorting</a>
            <a asp-controller="Home" asp-action="Trees" class="vs-nav-link">Trees</a>
            <a asp-controller="Home" asp-action="Graphs" class="vs-nav-link">Graphs</a>
            <a asp-controller="Home" asp-action="DynamicProgramming" class="vs-nav-link">DP</a>
            <a asp-controller="Home" asp-action="Greedy" class="vs-nav-link">Greedy</a>
            <a asp-controller="Home" asp-action="SearchingHashing" class="vs-nav-link vs-nav-link-active">Search</a>
            <a asp-controller="Home" asp-action="Heaps" class="vs-nav-link">Heaps</a>
            <a asp-controller="Home" asp-action="Strings" class="vs-nav-link">Strings</a>
            <a asp-controller="Home" asp-action="DivideConquer" class="vs-nav-link">D&amp;C</a>
            <a asp-controller="Home" asp-action="Geometry" class="vs-nav-link">Geometry</a>
        </div>
    </div>
</nav>

<section class="vs-algos-section vs-page-head" id="textbook-section" data-topic="searching">
    <div class="vs-container">
        <div class="vs-section-header">
            <span class="vs-eyebrow"><span class="vs-eyebrow-dot"></span>SEARCHING AND HASHING</span>
            <h1 class="vs-section-title">Pick a Searching or Hashing Topic</h1>
            <p class="vs-section-subtitle">Inspect comparisons, probes, chains, table slots, and probabilistic membership checks.</p>
        </div>
        <div class="vs-algo-grid" id="topic-grid"></div>
    </div>
</section>

<section class="vs-viz-section vs-hidden" id="topic-viz-section">
    <div class="vs-container">
        <button class="vs-back-btn" id="topic-back-btn" type="button">All Searching &amp; Hashing</button>
        <div class="vs-viz-inner">
            <div class="vs-viz-main">
                <div class="vs-viz-header"><h2 class="vs-viz-title" id="topic-title"></h2><span class="vs-category-badge vs-badge-topic" id="topic-category"></span></div>
                <div class="vs-topic-stage" id="topic-stage" role="img" aria-label="Algorithm visualization"></div>
                <div class="vs-stats-row">
                    <div class="vs-stat-box"><span class="vs-stat-box-num" id="topic-stat-active">0</span><span class="vs-stat-box-label">Active</span></div>
                    <div class="vs-stat-box"><span class="vs-stat-box-num" id="topic-stat-steps">0</span><span class="vs-stat-box-label">Steps</span></div>
                    <div class="vs-stat-box"><span class="vs-stat-box-num" id="topic-stat-status">Ready</span><span class="vs-stat-box-label">Status</span></div>
                </div>
                <div class="vs-controls">
                    <div class="vs-ctrl-btns">
                        <button class="vs-ctrl-btn" id="topic-reset" type="button">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                <path d="M2 8a6 6 0 1 1 1.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                <path d="M2 12V8h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Reset
                        </button>
                        <button class="vs-ctrl-btn vs-ctrl-btn-primary" id="topic-play" type="button">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                <path d="M5 3.5L13 8L5 12.5V3.5Z" fill="currentColor"/>
                            </svg>
                            Play
                        </button>
                        <button class="vs-ctrl-btn" id="topic-step" type="button">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                <path d="M4 3.5L10 8L4 12.5V3.5Z" fill="currentColor"/>
                                <line x1="12" y1="4" x2="12" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            Step
                        </button>
                    </div>
                    <div class="vs-sliders">
                        <label class="vs-slider-label">Speed <span class="vs-slider-val" id="topic-speed-val">5</span><input type="range" min="1" max="10" value="5" id="topic-speed" class="vs-slider" /></label>
                        <label class="vs-slider-label">Item Count <span class="vs-slider-val" id="topic-size-val">8</span><input type="range" min="4" max="14" value="8" id="topic-size" class="vs-slider" /></label>
                    </div>
                </div>
            </div>
            <div class="vs-info-panel">
                <div class="vs-complexity-grid">
                    <div class="vs-complexity-card"><span class="vs-complexity-label">Time</span><span class="vs-complexity-val" id="topic-cp-time"></span></div>
                    <div class="vs-complexity-card"><span class="vs-complexity-label">Space</span><span class="vs-complexity-val" id="topic-cp-space"></span></div>
                    <div class="vs-complexity-card"><span class="vs-complexity-label">Idea</span><span class="vs-complexity-val" id="topic-cp-idea"></span></div>
                    <div class="vs-complexity-card"><span class="vs-complexity-label">Result</span><span class="vs-complexity-val vs-complexity-val-worst" id="topic-cp-result"></span></div>
                </div>
                <div class="vs-info-card"><h4 class="vs-info-card-title">About</h4><p id="topic-description" class="vs-info-text"></p></div>
                <div class="vs-info-card"><h4 class="vs-info-card-title">Operation Log</h4><ol class="vs-tree-log" id="topic-log"></ol></div>
                <div class="vs-info-card"><h4 class="vs-info-card-title">Pseudocode</h4><pre class="vs-pseudocode" id="topic-pseudocode"></pre></div>
            </div>
        </div>
    </div>
</section>

@section Scripts { <script src="~/js/textbook-sections.js" asp-append-version="true"></script> }
