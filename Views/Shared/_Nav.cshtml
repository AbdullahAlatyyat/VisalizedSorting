@{
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? "Index");
    var active = (string action) => string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
        ? " vs-nav-link-active"
        : string.Empty;
    var isHome = string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);
}

<nav class="vs-nav" id="vs-nav" data-vs-nav>
    <div class="vs-nav-inner">
        <a asp-controller="Home" asp-action="Index" class="vs-nav-logo" aria-label="VisualizedAlgorithms home">
            <span class="logo-bracket">{</span>VisualizedAlgorithms<span class="logo-bracket">}</span>
        </a>
        <button class="vs-nav-toggle" type="button" aria-controls="vs-nav-menu" aria-expanded="false" aria-label="Open navigation">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <div class="vs-nav-links vs-nav-menu" id="vs-nav-menu">
            <a asp-controller="Home" asp-action="Sorting" class="vs-nav-link@(active("Sorting"))">Sorting</a>
            <a asp-controller="Home" asp-action="Trees" class="vs-nav-link@(active("Trees"))">Trees</a>
            <a asp-controller="Home" asp-action="Graphs" class="vs-nav-link@(active("Graphs"))">Graphs</a>
            <a asp-controller="Home" asp-action="DynamicProgramming" class="vs-nav-link@(active("DynamicProgramming"))">DP</a>
            <a asp-controller="Home" asp-action="Greedy" class="vs-nav-link@(active("Greedy"))">Greedy</a>
            <a asp-controller="Home" asp-action="SearchingHashing" class="vs-nav-link@(active("SearchingHashing"))">Search</a>
            <a asp-controller="Home" asp-action="Heaps" class="vs-nav-link@(active("Heaps"))">Heaps</a>
            <a asp-controller="Home" asp-action="Strings" class="vs-nav-link@(active("Strings"))">Strings</a>
            <a asp-controller="Home" asp-action="DivideConquer" class="vs-nav-link@(active("DivideConquer"))">D&amp;C</a>
            <a asp-controller="Home" asp-action="Geometry" class="vs-nav-link@(active("Geometry"))">Geometry</a>
            @if (isHome)
            {
                <a asp-controller="Home" asp-action="Sorting" class="vs-nav-cta">Start Visualizing</a>
            }
        </div>
    </div>
</nav>
